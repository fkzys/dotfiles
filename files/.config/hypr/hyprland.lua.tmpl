------------------
---- MONITORS ----
------------------

-- See https://wiki.hypr.land/Configuring/Basics/Monitors/
{{- if and (hasKey $hyprland .hostname) (hasKey (index $hyprland .hostname) "monitor") }}
-- Parse monitor string from secrets: "output,mode,position,scale"
local mon_str = "{{ index $hyprland .hostname "monitor" }}"
local mon_output, mon_mode, mon_pos, mon_scale = mon_str:match("([^,]+),([^,]+),([^,]+),([^,]+)")
if mon_output and mon_output ~= "" then
    hl.monitor({ output = mon_output, mode = mon_mode, position = mon_pos, scale = mon_scale })
end
{{- end }}
hl.monitor({ output = "", mode = "preferred", position = "auto", scale = "auto" })


-----------------------------
---- ENVIRONMENT VARIABLES ---
-----------------------------

-- See https://wiki.hypr.land/Configuring/Advanced-and-Cool/Environment-variables/
-- Essential for Nvidia on Wayland
{{- if eq .nvidia true }}
hl.env("LIBVA_DRIVER_NAME", "nvidia")
hl.env("XDG_SESSION_TYPE", "wayland")
hl.env("GBM_BACKEND", "nvidia-drm")
hl.env("__GLX_VENDOR_LIBRARY_NAME", "nvidia")
hl.env("WLR_NO_HARDWARE_CURSORS", "1")
{{- end }}

-- Theming and Cursor
hl.env("XCURSOR_SIZE", "24")
hl.env("HYPRCURSOR_SIZE", "24")
hl.env("QT_QPA_PLATFORMTHEME", "qt6ct")

-- Input Method
hl.env("QT_IM_MODULE", "fcitx")
hl.env("QT_IM_MODULES", "wayland;fcitx;ibus")
hl.env("XMODIFIERS", "@im=fcitx")


-------------------
---- AUTOSTART ----
-------------------

-- Autostart necessary processes (like notifications daemons, status bars, etc.)
-- Or execute your favorite apps at launch like this:

-- D-Bus
-- hl.on("hyprland.start", function()
--     hl.exec_cmd("dbus-update-activation-environment --systemd WAYLAND_DISPLAY XDG_CURRENT_DESKTOP HYPRLAND_INSTANCE_SIGNATURE")
-- end)

hl.on("hyprland.start", function()
    -- Apply GTK Theme
    hl.exec_cmd("gsettings set org.gnome.desktop.interface gtk-theme 'Materia-dark'")
    hl.exec_cmd("gsettings set org.gnome.desktop.interface icon-theme 'Papirus'")
    hl.exec_cmd("gsettings set org.gnome.desktop.interface color-scheme 'prefer-dark'")

    -- Input Method
    hl.exec_cmd("fcitx5 -dr")

end)


